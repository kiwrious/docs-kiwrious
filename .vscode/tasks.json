{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve docs (http-server)",
      "type": "shell",
      "command": "npx --yes http-server . -p 8080 -c-1 --cors",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            { "regexp": ".", "file": 1, "location": 2, "message": 3 }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Starting up http-server",
            "endsPattern": "Available on:"
          }
        }
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Serve docs (Python)",
      "type": "shell",
      "command": "python3 -m http.server 8080",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Open docs in browser",
      "type": "shell",
      "command": "open http://localhost:8080",
      "problemMatcher": []
    }
  ]
}
